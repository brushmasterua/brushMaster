generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Категорії товарів
model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

// Товари
model Product {
  id          Int         @id @default(autoincrement())
  name        String
  slug        String      @unique
  description String?
  price       Decimal     @db.Decimal(10, 2)
  oldPrice    Decimal?    @db.Decimal(10, 2)
  stock       Int         @default(0)
  image       String
  imagePublicId String?
  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[] // ← ДОДАНО: зворотне відношення
  isNew       Boolean     @default(false)
  isHit       Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// Замовлення
model Order {
  id            Int         @id @default(autoincrement())
  orderNumber   String      @unique
  customerName  String      // Ім'я клієнта
  customerPhone String      // Телефон
  customerEmail String?     // Email
  customerCity  String      // Місто
  customerAddress String    // Адреса
  deliveryMethod String     // nova, ukrposhta, courier
  paymentMethod String      // card, cash
  comment       String?     // Коментар
  total         Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  items         OrderItem[]
}

// Товари в замовленні
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}